{
    "$comment" : "JSON Schema for TestGatewayPing test parameters",
    "$comment" : "",
    "$comment" : "Version 1.0, 08/13/2019",
    "$comment" : "",

    "$schema": "http://json-schema.org/draft-06/schema#",
    "id": "https://128technology.com/schemas/GatewayPing.json#",
    "title": "DeviceNamespace",
    "description": "Refine Device Namespace Test Behavior",
    "type" : "object",
    "properties" : {
        "node_type" : { "type" : "string" },
        "device-interfaces"  : {
            "type"  : "array",
            "items" : { "type" : "string" }
        },
        "network-interfaces"  : {
            "type"  : "array",
            "items" : { "type" : "string" }
        },
        "sequence"    : {
            "type"    : "integer",
            "minimum" : 0
        },
        "size" : {
            "type"    : "integer",
            "minimum" : 1,
            "default" : 100
        },
        "timeout" : {
             "type"    : "integer",
             "minimum" : 1
        },
        "identifier" : {
             "type"    : "integer",
             "minimum" : 0
        },
        "iterations" : {
             "type"    : "integer",
             "minimum" : 1
        },
        "destination-ip" : {
            "type" : "string",
            "oneOf" : [
                { "format" : "ipv4" },
                { "format" : "ipv6" }
             ]
         },
        "static-address" : { "type" : "boolean" }
    },
    "required" : [ "node_type" ],
    "oneOf" : [
       {
           "required" : [ "device-interfaces" ]
       },
       {
           "required" : [ "network-interfaces" ]
       }
    ]
}
